# MiniMax API key used by apps/api/src/adapters/minimax/adapter.ts.
MINIMAX_API_KEY=

# CosyVoice / DashScope Model Studio
COSYVOICE_API_KEY=
COSYVOICE_WORKSPACE_ID=
COSYVOICE_REGION=cn-beijing
# Optional. Allows stream TTS without COSYVOICE_WORKSPACE_ID. CosyVoice task frames use /inference.
COSYVOICE_STREAM_ENDPOINT=wss://dashscope.aliyuncs.com/api-ws/v1/inference
# COSYVOICE_API_KEY can also fall back to DASHSCOPE_API_KEY.
DASHSCOPE_API_KEY=
DASHSCOPE_INFERENCE_ENDPOINT=wss://dashscope.aliyuncs.com/api-ws/v1/inference
# DashScope /realtime uses a different protocol and is not enabled by the CosyVoice task-frame transport yet.
DASHSCOPE_REALTIME_ENDPOINT=

# Optional API server binding.
PORT=4000
HOST=0.0.0.0
